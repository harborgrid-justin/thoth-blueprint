{
  "name": "@thoth/service-geospatial",
  "version": "0.1.0",
  "private": true,
  "description": "Geospatial & interoperability for Thoth Blueprint — CRS transforms, layers, spatial ops, and import/export (GeoJSON, KML, Shapefile, DXF, PDF).",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@thoth/domain": "^0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "proj4": "^2.15.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.2",
    "@types/proj4": "^2.12.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "license": "GPL-3.0-or-later"
}
