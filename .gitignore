# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Rust workspace (crates/*) build artifacts
target/
**/*.rs.bk
*.pdb

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln


*.sw?
dev-dist
.qwen
samples
dev

# Environment / secrets (cloud platform)
.env
.env.*
!.env.example

# Monorepo build outputs & caches
build
out
coverage
.turbo
.next
*.tsbuildinfo

# Infrastructure / local state
.terraform
*.tfstate
*.tfstate.*
# Test directories
test/
tests/
__tests__/
spec/
e2e/
# The blanket `tests/` rule above is unanchored and would otherwise also
# swallow legitimate Rust integration-test directories (`cargo test`'s
# `crates/<crate>/tests/` convention, e.g. crates/thoth-bindings/tests/) --
# those are source, not build output. Un-ignore them explicitly.
!crates/**/tests/
!crates/**/tests/**

# Playwright report data
apps/web/playwright-report/data/

# Test results
apps/web/test-results/

# Local SQLite storage (default @thoth/storage backend — runtime data, not source)
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
services/*/data/
