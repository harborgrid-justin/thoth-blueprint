{
  "name": "@thoth/domain",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic planning domain model for Thoth Blueprint (sites, parcels, zones, land use, and the rules over them).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "yarn run tsc -p tsconfig.json",
    "type-check": "yarn run tsc -p tsconfig.json --noEmit",
    "test": "yarn run vitest run",
    "test:watch": "yarn run vitest",
    "lint": "yarn run eslint src"
  },
  "keywords": [
    "planning",
    "site-planning",
    "urban-planning",
    "geospatial",
    "domain-model"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/gl-matrix": "^2.4.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.10.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "gl-matrix": "^3.4.4",
    "lodash": "^4.18.1"
  }
}
