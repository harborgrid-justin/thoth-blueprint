{
  "name": "@thoth/domain",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic planning domain model for Thoth Blueprint (sites, parcels, zones, land use, and the rules over them).",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "planning",
    "site-planning",
    "urban-planning",
    "geospatial",
    "domain-model"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "GPL-3.0-or-later"
}
