{
  "name": "@thoth/storage",
  "version": "0.1.0",
  "private": true,
  "description": "Default internal storage layer for Thoth Blueprint — a pluggable StorageAdapter backed by SQLite by default, swappable for an enterprise database without changing call sites.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "yarn run tsc -p tsconfig.json",
    "type-check": "yarn run tsc -p tsconfig.json --noEmit",
    "test": "yarn run vitest run",
    "test:watch": "yarn run vitest",
    "lint": "yarn run eslint src"
  },
  "keywords": [
    "storage",
    "sqlite",
    "persistence",
    "adapter"
  ],
  "dependencies": {
    "better-sqlite3": "^13.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.9"
  },
  "license": "GPL-3.0-or-later"
}
